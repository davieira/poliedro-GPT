# URL pública da API (ChatGPT Actions exige no OpenAPI servers)
# No Render, RENDER_EXTERNAL_URL é preenchido automaticamente.
# API_BASE_URL=https://poliedro-api.onrender.com

# Chave que o ChatGPT envia no header X-API-Key
API_KEY=troque-por-uma-chave-forte

# Token JWT do Poliedro (obtido após login no P+)
POLIEDRO_TOKEN=

# Config completo em JSON (uma linha). Alternativa ao arquivo config/config.json
# POLIEDRO_CONFIG_JSON={"base_url":"https://poliedro-api.p4ed.com","auth":{"username":"seu.usuario"},"student":{...},"calendar":{...},"notifications":{...}}

# Caminho alternativo para config.json (local/Docker)
# POLIEDRO_CONFIG=/caminho/config.json
