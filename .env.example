# URL pública da API (ChatGPT Actions exige no OpenAPI servers)
# Obrigatório com domínio customizado — senão o Render usa RENDER_EXTERNAL_URL (*.onrender.com).
# API_BASE_URL=https://poliedro-api.iden.is

# OAuth para ChatGPT (modo multi-usuário — recomendado)
OAUTH_CLIENT_ID=poliedro-gpt
OAUTH_CLIENT_SECRET=troque-por-um-secret-forte

# Chave legada para modo single-user (opcional com OAuth)
API_KEY=

# Modo single-user (opcional): token JWT fixo do Poliedro
POLIEDRO_TOKEN=

# Modo single-user (opcional): config completo em JSON (uma linha)
# POLIEDRO_CONFIG_JSON={"base_url":"https://poliedro-api.p4ed.com","auth":{"username":"seu.usuario"},"student":{...},"calendar":{...},"notifications":{...}}

# Modo multi-usuário: basta API_KEY. Cada cliente autentica em POST /api/v1/auth/login
# e envia Authorization: Bearer <token> nas demais requisições.

# Caminho alternativo para config.json (local/Docker)
# POLIEDRO_CONFIG=/caminho/config.json
